      data:
        title: Start from a fixed scramble
        stateSetup:
          isEnabled: 1
          mode: 0
          scrambleMoves:
          - R
          - U
          - R'
          - U'
          - F
          - U
          - F'
        body: This guide starts from a known scramble so the lesson player can show
          the same pieces every time.
