{
  "$schema": "https://dotnet.github.io/docfx/schemas/docfx.schema.json",
  "build": {
    "content": [
      {
        "files": [
          "**/*.md",
          "**/toc.yml"
        ],
        "src": "Docs",
        "dst": ".",
        "markdownEngineProperties": {
          "alerts": {
            "TODO": "alert alert-secondary"
          }
        }
      }
    ],
    "resource": [
      {
        "files": [
          "Docs/images/**"
        ],
        "exclude": [
          "**/.git/**"
        ]
      }
    ],
    "dest": "_site",
    "globalMetadata": {
      "_appTitle": "Cubetorial Docs"
    },
    "template": [
      "default",
      "modern"
    ]
  }
}
